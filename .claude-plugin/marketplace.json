{
  "name": "ZebLawrence-agent-resources",
  "owner": {
    "name": "ZebLawrence"
  },
  "plugins": [
    {
      "name": "shared-agent-resources",
      "source": "./",
      "description": "Shared skills, agents, and MCP server configurations",
      "skills": ["./skills/template-skill"],
      "mcpServers": {
        "playwright": {
          "command": "npx",
          "args": ["-y", "@playwright/mcp@latest"]
        },
        "io.github.ChromeDevTools/chrome-devtools-mcp": {
          "command": "npx",
          "args": ["-y", "chrome-devtools-mcp"],
          "env": {},
          "type": "stdio"
        },
        "remotion-documentation": {
          "command": "npx",
          "args": ["@remotion/mcp@latest"],
          "type": "stdio"
        }
      }
    },
    {
      "name": "zeb-message",
      "source": "./plugins/zeb-message",
      "description": "Custom iMessage channel for Claude Code — reads chat.db directly, sends via AppleScript."
    }
  ]
}
